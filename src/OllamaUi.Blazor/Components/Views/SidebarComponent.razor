@rendermode InteractiveServer

<style>
  .guide-line {
    border-bottom: 2px solid #000000;
  }

  .hoverable[SidebarComponent] {
    user-select: none;
    cursor: pointer;
  }

  .selected[SidebarComponent] {
    background-color: #0040FF80;
  }
</style>

<div class="container-fluid" style="width: 100%; height: 100%">
  <RadzenCard style="width: 100%; height: 100%; overflow-y: auto">
    <div class='row mb-2 mt-2 hoverable @GetClass("message")' @onclick='@(() => OnElementClickedAsync(_messageManifest))' SidebarComponent>
      <div class="col-12">
        Message
      </div>
    </div>
    <div class='row mb-2 mt-2 hoverable @GetClass("chat")' @onclick='@(() => OnElementClickedAsync(_newChatManifest))' SidebarComponent>
      <div class="col-12">
        New chat
      </div>
    </div>
    <div class="row">
      <div class="col-12 guide-line">
      </div>
    </div>
    @foreach (var manifest in SavedChats)
    {
      <div class='row mb-2 mt-2 d-flex align-items-center @GetClass(manifest.ChatId.ToString("d"))' SidebarComponent>
        <div class="col-10 hoverable" @onclick='@(() => OnElementClickedAsync(manifest))' SidebarComponent>
          @manifest.DisplayName
        </div>
        <div class="col-1 p-0 d-flex align-items-center hoverable" @onclick="@(() => OnEditDisplayNameClickedAsync(manifest))" SidebarComponent>
          <RadzenIcon Icon="edit"/>
        </div>
        <div class="col-1 p-0 d-flex align-items-center hoverable" @onclick="@(() => OnDeleteChatClicked(manifest))" SidebarComponent>
          <RadzenIcon Icon="delete"/>
        </div>
      </div>
    }
  </RadzenCard>
</div>
